# Boxento Backend Configuration
PORT=3001
DATABASE_PATH=/data/boxento.db

# Optional: Tailscale Serve read-only route discovery.
# Use the CLI by default when `tailscale` is available to the backend process.
# TAILSCALE_CLI_PATH=/usr/local/bin/tailscale
# TAILSCALE_SERVE_STATUS_URL=http://127.0.0.1:8787/tailscale/serve-status
# TAILSCALE_SERVE_STATUS_FILE=/data/tailscale-serve-status.json
# TAILSCALE_SERVE_STATUS_JSON={"TCP":{},"Web":{}}
