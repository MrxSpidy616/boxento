# Google OAuth Configuration
# Create a project in Google Cloud Console: https://console.cloud.google.com/
# Enable the Google Calendar API
# Create OAuth 2.0 credentials and add authorized redirect URIs
# Add your domain to the authorized JavaScript origins

# Replace with your actual Google OAuth client ID
VITE_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloud Function URLs for secure OAuth token handling
# These are generated when you deploy Firebase Cloud Functions
# Example: https://us-central1-your-project.cloudfunctions.net/oauthExchange
VITE_PUBLIC_OAUTH_EXCHANGE_URL=
VITE_PUBLIC_OAUTH_REFRESH_URL=

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# SQLite Backend Configuration (Self-Hosted Mode)
# When set, Boxento will use the SQLite backend for data persistence instead of Firebase.
# This enables data sharing across all devices without requiring authentication.
# The backend API is provided by the boxento-backend service.
#
# Example: http://localhost:3001/api (local development)
# Example: http://boxento-backend:3001/api (Docker Compose)
# Example: https://mini.tailf2415.ts.net:3001/api (Tailscale network)
VITE_SQLITE_API_URL=

# Add any other environment variables your app needs below
